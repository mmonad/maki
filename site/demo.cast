[25.823802, "o", "\u001b[1;1H\u001b[38;2;40;42;54;48;2;189;147;249m /tasks     Browse and search tasks \u001b[39;48;2;40;42;54m                                          \u001b[2;1H \u001b[38;2;139;233;253;48;2;40;42;54m/compact\u001b[39;48;2;40;42;54m   \u001b[38;2;98;114;164;48;2;40;42;54mSummarize and compact conversation history\u001b[39;48;2;40;42;54m                        \u001b[3;1H \u001b[38;2;139;233;253;48;2;40;42;54m/new\u001b[39;48;2;40;42;54m       \u001b[38;2;98;114;164;48;2;40;42;54mStart a new session\u001b[39;48;2;40;42;54m                                               \u001b[4;1H \u001b[38;2;139;233;253;48;2;40;42;54m/help\u001b[39;48;2;40;42;54m      \u001b[38;2;98;114;164;48;2;40;42;54mShow keybindings\u001b[39;48;2;40;42;54m                                                  \u001b[5;1H \u001b[38;2;139;233;253;48;2;40;42;54m/usage\u001b[39;48;2;40;42;54m     \u001b[38;2;98;114;164;48;2;40;42;54mShow token usage breakdown\u001b[39;48;2;40;42;54m                                        \u001b[6;2H\u001b[38;2;139;233;253;48;2;40;42;54m/queue\u001b[6;13H\u001b[38;2;98;114;164;48;2;40;42;54mRemove items from queue\u001b[7;1H\u001b[39;48;2;40;42;54m \u001b[38;2;139;233;253;48;2;40;42;54m/model\u001b[39;48;2;40;42;54m     \u001b[38;2;98;114;164;48;2;40;42;54mSwitch model\u001b[39;48;2;40;42;54m                                                      \u001b[8;1H \u001b[38;2;139;233;253;48;2;40;42;54m/theme\u001b[39;48;2;40;42;54m     \u001b[38;2;98;114;164;48;2;40;42;54mSwitch color theme\u001b[39;48;2;40;42;54m                   \u001b[9;2H\u001b[38;2;139;233;253;48;2;40;42;54m/mcp\u001b[9;13H\u001b[38;2;98;114;164;48;2;40;42;54mConfigure MCP servers\u001b[10;1H\u001b[39;48;2;40;42;54m \u001b[38;2;139;233;253;48;2;40;42;54m/login\u001b[39;48;2;40;42;54m     \u001b[38;2;98;114;164;48;2;40;42;54mAuthenticate with an LLM provider\u001b[39;48;2;40;42;54m                                 \u001b[11;1H \u001b[38;2;139;233;253;48;2;40;42;54m/cd\u001b[39;48;2;40;42;54m        \u001b[38;2;98;114;164;48;2;40;42;54mChange working directory\u001b[39;48;2;40;42;54m                                          \u001b[12;1H \u001b[38;2;139;233;253;48;2;40;42;54m/btw\u001b[39;48;2;40;42;54m       \u001b[38;2;98;114;164;48;2;40;42;54mAsk a quick question (no tools, no history pollution)\u001b[39;48;2;40;42;54m             \u001b[13;1H"]
[25.824085, "o", " \u001b[38;2;139;233;253;48;2;40;42;54m/yolo\u001b[39;48;2;40;42;54m      \u001b[38;2;98;114;164;48;2;40;42;54mToggle YOLO mode (skip all permission prompts)\u001b[39;48;2;40;42;54m                    \u001b[14;1H \u001b[38;2;139;233;253;48;2;40;42;54m/thinking\u001b[39;48;2;40;42;54m  \u001b[38;2;98;114;164;48;2;40;42;54mToggle extended thinking (off, adaptive, effort level, or budget)\u001b[39;48;2;40;42;54m \u001b[15;2H\u001b[38;2;139;233;253;48;2;40;42;54m/fast\u001b[15;13H\u001b[38;2;98;114;164;48;2;40;42;54mToggle Anthropic fast mode (Opus only)\u001b[16;1H\u001b[39;48;2;40;42;54m \u001b[38;2;139;233;253;48;2;40;42;54m/workflow\u001b[39;48;2;40;42;54m  \u001b[38;2;98;114;164;48;2;40;42;54mToggle workflow mode (task callable inside code_execution)\u001b[17;2H\u001b[38;2;139;233;253;48;2;40;42;54m/exit\u001b[17;13H\u001b[38;2;98;114;164;48;2;40;42;54mExit the application\u001b[18;1H\u001b[39;48;2;40;42;54m \u001b[38;2;139;233;253;48;2;40;42;54m/reload\u001b[39;48;2;40;42;54m    \u001b[38;2;98;114;164;48;2;40;42;54mReload plugins and config\u001b[39;48;2;40;42;54m                                         \u001b[20;3H\u001b[38;2;248;248;242;48;2;40;42;54m/\u001b[7m \u001b[27m                     \u001b[22;2H\u001b[38;2;241;250;140;48;2;40;42;54m⠧\u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25l"]
